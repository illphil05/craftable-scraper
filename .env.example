# Copy this file to .env and fill in real values before running docker compose.
# Never commit the .env file — it is listed in .gitignore.

# Required — used to authenticate API requests (X-API-Key header)
SCRAPER_API_KEY=change-me-to-a-long-random-string

# Required — password for the browser UI
SITE_PASSWORD=change-me-to-a-strong-password

# Optional — SQLite database path inside the container (default: /data/scraper.db)
# SCRAPER_DB_PATH=/data/scraper.db

# Optional — max simultaneous Playwright browsers (default: 3)
# MAX_CONCURRENT_SCRAPERS=3

# Optional — hours between scheduled re-scrape cycles (0 = disabled, default: 24)
# SCRAPE_INTERVAL_HOURS=24

# Optional — log level (DEBUG, INFO, WARNING, ERROR; default: INFO)
# LOG_LEVEL=INFO
